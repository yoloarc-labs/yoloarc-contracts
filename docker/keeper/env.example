# Marking keeper 容器环境变量样例
# 复制为 .env (无点前缀的 env.example 是样例, .env 由用户自己创建填写, 不提交)
# .env 由用户自己填, AI 不动

# BSC 主网 RPC
RPC_URL=https://bsc-dataseed.binance.org
CHAIN_ID=56

# Marking 代理地址 (部署后回填)
MARKING_ADDRESS=

# keeper 私钥 (明文, ENV 注入; 该账户在 Marking 上授 KEEPER_ROLE, 最小权限只能触发做市, 不能提现)
# 带/不带 0x 前缀均可, entrypoint 自动补
PRIVATE_KEY=

# 执行间隔 (秒), 默认 300 = 5 分钟
INTERVAL_SECONDS=300

# 单笔 gas 上限
GAS_LIMIT=300000
